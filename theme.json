{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "color": {
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "slug": "breaking",         "name": "Breaking News",    "color": "#D60000" },
                { "slug": "primary",          "name": "Primary Accent",   "color": "#C40000" },
                { "slug": "dark-bg",          "name": "Dark Background",  "color": "#111111" },
                { "slug": "light-bg",         "name": "Light Background", "color": "#F5F5F5" },
                { "slug": "text-primary",     "name": "Text Primary",     "color": "#1A1A1A" },
                { "slug": "text-secondary",   "name": "Text Secondary",   "color": "#666666" },
                { "slug": "border",           "name": "Border",           "color": "#E5E5E5" }
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontSizes": [
                { "slug": "meta",     "name": "Meta",      "size": "13px",  "fluid": { "min": "12px", "max": "14px" } },
                { "slug": "compact",  "name": "Compact",   "size": "16px",  "fluid": { "min": "15px", "max": "18px" } },
                { "slug": "card",     "name": "Card",      "size": "22px",  "fluid": { "min": "20px", "max": "28px" } },
                { "slug": "section",  "name": "Section",   "size": "28px",  "fluid": { "min": "24px", "max": "32px" } },
                { "slug": "lead",     "name": "Lead",      "size": "36px",  "fluid": { "min": "32px", "max": "40px" } },
                { "slug": "hero",     "name": "Hero H1",   "size": "56px",  "fluid": { "min": "48px", "max": "64px" } }
            ]
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "units": ["px", "rem", "em", "%", "vw", "vh"],
            "spacingScale": {
                "operator": "*",
                "increment": 1.5,
                "steps": 7,
                "mediumStep": 1.5,
                "unit": "rem"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--light-bg)",
            "text": "var(--wp--preset--color--text-primary)"
        }
    }
}
