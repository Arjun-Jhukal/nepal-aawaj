            "type": "image",
            "instructions": "Used by na_thumb() when a post has no featured image.",
            "return_format": "array",
            "preview_size": "medium",
            "library": "all"
        },
        {
            "key": "field_ts_favicon",
            "label": "Favicon",
            "name": "ts_favicon",
            "type": "image",
            "instructions": "Square PNG, 512×512 recommended.",
            "return_format": "array",
            "preview_size": "thumbnail",
            "library": "all"
        },
        {
            "key": "field_ts_theme_color",
            "label": "Theme color",
            "name": "ts_theme_color",
            "type": "color_picker",
            "instructions": "Browser chrome + mobile address bar color.",
            "default_value": "#DC1F26"
        },

        {
            "key": "field_ts_tab_seo",
            "label": "SEO",
            "name": "",
            "type": "tab",
            "placement": "top",
            "endpoint": 0
        },
        {
            "key": "field_ts_no_index",
            "label": "Hide from search engines",
            "name": "ts_no_index",
            "type": "true_false",
            "instructions": "Emits noindex,nofollow on every page. Turn off once the site goes live.",
            "ui": 1,
            "default_value": 1
        },
        {
            "key": "field_ts_og_image",
            "label": "Default social image",
            "name": "ts_og_image",
            "type": "image",
            "instructions": "Used as og:image when a post has no featured image. 1200×630 recommended.",
