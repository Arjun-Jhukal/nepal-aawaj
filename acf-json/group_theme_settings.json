            "name": "",
            "type": "tab",
            "placement": "top",
            "endpoint": 0
        },
        {
            "key": "field_ts_logo",
            "label": "Logo",
            "name": "ts_logo",
            "type": "image",
            "instructions": "Falls back to the built-in SVG when empty.",
            "return_format": "array",
            "preview_size": "medium",
            "library": "all"
        },
        { "key": "field_ts_site_name",        "label": "Site name",         "name": "ts_site_name",        "type": "text", "wrapper": { "width": "50" }, "default_value": "RASTRIYA AAWAJ" },
        { "key": "field_ts_site_tagline",     "label": "Site tagline",      "name": "ts_site_tagline",     "type": "text", "wrapper": { "width": "50" }, "default_value": "सत्य, निष्पक्ष र राष्ट्रको आवाज" },
        { "key": "field_ts_site_description", "label": "Site description",  "name": "ts_site_description", "type": "textarea", "rows": 3, "new_lines": "", "default_value": "राष्ट्रिय आवाज एक स्वतन्त्र डिजिटल समाचार पोर्टल हो, जसले सत्य, निष्पक्ष र विश्वसनीय समाचार र विश्लेषण प्रस्तुत गर्दछ।" },
        { "key": "field_ts_copyright",        "label": "Copyright line",    "name": "ts_copyright",        "type": "text", "default_value": "Rastriya Aawaj Media Pvt. Ltd. · सर्वाधिकार सुरक्षित" },
        {
            "key": "field_ts_placeholder_image",
